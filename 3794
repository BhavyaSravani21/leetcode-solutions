class Solution(object):
    def sumAndMultiply(self, n):
        """
        :type n: int
        :rtype: int
        """
        x = 0
        digit_sum = 0
        for ch in str(n):
            digit = int(ch)
            if digit != 0:
                x = x * 10 + digit
                digit_sum += digit
        return x * digit_sum
        
