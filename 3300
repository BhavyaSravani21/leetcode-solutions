class Solution(object):
    def minElement(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        def digit_sum(n):
            s = 0
            while n > 0:
                s += n % 10
                n //= 10
            return s
        mini = float('inf')
        for num in nums:
            mini = min(mini, digit_sum(num))
        return mini
        
