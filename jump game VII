class Solution(object):
    def canReach(self, s, minJump, maxJump):
        """
        :type s: str
        :type minJump: int
        :type maxJump: int
        :rtype: bool
        """
        n = len(s)
        visited = [False] * n
        visited[0] = True
        reachable = 0
        for i in range(1, n):
            if i - minJump >= 0 and visited[i - minJump]:
                reachable += 1
            if i - maxJump - 1 >= 0 and visited[i - maxJump - 1]:
                reachable -= 1
            if s[i] == '0' and reachable > 0:
                visited[i] = True
        return visited[n - 1]
        
