from bisect import bisect_right

class Solution(object):
    def earliestFinishTime(self, landStartTime, landDuration,
                           waterStartTime, waterDuration):

        def build(start, duration):
            rides = sorted(zip(start, duration))

            s = [x[0] for x in rides]
            d = [x[1] for x in rides]

            n = len(rides)

            # prefix minimum duration
            pref = [0] * n
            pref[0] = d[0]

            for i in range(1, n):
                pref[i] = min(pref[i - 1], d[i])

            # suffix minimum (start + duration)
            suff = [0] * n
            suff[n - 1] = s[n - 1] + d[n - 1]

            for i in range(n - 2, -1, -1):
                suff[i] = min(suff[i + 1],
                              s[i] + d[i])

            return s, pref, suff

        waterS, waterPref, waterSuff = build(
            waterStartTime, waterDuration
        )

        landS, landPref, landSuff = build(
            landStartTime, landDuration
        )

        ans = float("inf")

        # Land -> Water
        for st, dur in zip(landStartTime, landDuration):

            t = st + dur
            idx = bisect_right(waterS, t)

            best = float("inf")

            if idx > 0:
                best = min(best, t + waterPref[idx - 1])

            if idx < len(waterS):
                best = min(best, waterSuff[idx])

            ans = min(ans, best)

        # Water -> Land
        for st, dur in zip(waterStartTime, waterDuration):

            t = st + dur
            idx = bisect_right(landS, t)

            best = float("inf")

            if idx > 0:
                best = min(best, t + landPref[idx - 1])

            if idx < len(landS):
                best = min(best, landSuff[idx])

            ans = min(ans, best)

        return ans
